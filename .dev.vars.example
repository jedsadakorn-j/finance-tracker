# Copy this file to `.dev.vars` for local development (used by Wrangler/Vite).
# In production, set these with: wrangler secret put <NAME>
# NEVER commit the real .dev.vars file.

# Secret used to sign session cookies (HMAC). Use a long random string.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET="dev-only-insecure-secret-change-me"
